# Animal Rescue Network — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/animal_rescue

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=https://your-vercel-app.vercel.app
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Email / SMTP (leave blank to disable email — in-app notifications still work) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Animal Rescue Network <noreply@animalrescue.com>

# ── Cloudinary (required for photo uploads) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
